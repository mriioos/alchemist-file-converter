# Development configuration — safe to commit, contains no secrets.

# ── Backend ──────────────────────────────────────────────────────────────────
FC_WORK_DIR=/tmp/conversions
FC_TASK_TTL_SECONDS=1800
FC_MAX_UPLOAD_BYTES=52428800
FC_LIBREOFFICE_TIMEOUT=120
FC_GHOSTSCRIPT_TIMEOUT=120

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=4321

# ── Frontend ──────────────────────────────────────────────────────────────────
# Points the browser to the backend.
# In dev, both are on localhost so this is explicit.
PUBLIC_API_BASE=http://localhost:8000
