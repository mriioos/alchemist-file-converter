FROM node:22-alpine

WORKDIR /app

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Source (src/, public/, astro.config.mjs, etc.) is mounted as a volume
# node_modules are installed at container startup via entrypoint
EXPOSE 4321
ENTRYPOINT ["/entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
