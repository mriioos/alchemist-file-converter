# ── Secrets ───────────────────────────────────────────────────────────────────
.env*
!.env.config*
!.env.credentials.example

# Explicitly ignore credentials files (extra security layer)
.env.credentials

# ── Runtime data (bind-mounted volumes) ───────────────────────────────────────
# All runtime data lives here locally. Not tracked in git.
volume_mounts/
.dev

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
.venv/
venv/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.astro/
npm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
# docker-compose.override.yml is intentionally not gitignored
# so local overrides are not accidentally created

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

