# ── Credentials template ──────────────────────────────────────────────────────
# Copy this file to .env.credentials and fill in the values.
# .env.credentials is gitignored — never commit it.
#
# Run with:
#   docker compose -f docker-compose.prod.yml \
#     --env-file .env.config.prod \
#     --env-file .env.credentials \
#     up --build

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token from Cloudflare Zero Trust dashboard (Access → Tunnels → your tunnel → configure).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Domain ─────────────────────────────────────────────────────────────────
# The hostname clients use to reach the server (no protocol, no trailing slash).
# Used by Authelia to scope session cookies and build redirect URLs.
# IMPORTANT: Authelia does NOT accept 'localhost' — use an IP or a real domain.
# Local testing : 127.0.0.1
# LAN            : 192.168.1.10
# Internet       : converter.yourdomain.com
DOMAIN=

# ── Authelia secrets ──────────────────────────────────────────────────────────
# All three must be strong random strings.
# Generate each with:  openssl rand -hex 64

# Used to sign password-reset JWT tokens
AUTHELIA_JWT_SECRET=

# Used to encrypt session cookies
AUTHELIA_SESSION_SECRET=

# Used to encrypt the SQLite database at rest (must be 64+ chars)
AUTHELIA_STORAGE_ENCRYPTION_KEY=